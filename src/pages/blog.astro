---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogList from "../components/blog/BlogList.astro";

const metaDescription = "Dr Naomi Fisher's Substack blog";
---

<BaseLayout active="blog" pageTitle="Blog" metaDescription={metaDescription}>
  <a id="blog" class="anchor">
    <h1 class="section-title">
      <span class="">Articles</span>
    </h1>
  </a>
  <p>
    My free Substack newsletter provides a psychological perspective on the challenges families are facing today. It covers a range of diverse topics, from school problems and anxiety to the nuts and bolts of self-directed education. There’s an archive of my past writings on Substack and they are easy to share with people who aren’t on social media. If you sign up, you’ll get a short post each week directly to your inbox.
  </p>
  <h2 class="section-title">
    <span class="courses-section-title">Featured Substack posts</span>
  </h2>
  <BlogList featured={true} />

  <!--<h2 class="section-title">-->
  <!--  <span class="courses-section-title">Latest posts</span>-->
  <!--</h2>-->
  <!--<BlogList />-->
</BaseLayout>
