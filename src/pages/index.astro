---
import BaseLayout from "../layouts/BaseLayout.astro";
import getWebinars from "../scripts/webinars.js";
import WebinarSummary from "../components/webinar/WebinarSummary.astro";

import GenerateQuote from "../components/Quoter";
import { getEntry } from "astro:content";

import { getFeaturedCourses } from "../scripts/courses";
import CoursesList from "../components/course/CoursesList.astro";
import CoursesListV2 from "../components/course/CoursesListV2.astro";
import BookSummary from "../components/book/BookSummaryV2.astro";
import { getFeaturedBooks } from "../scripts/book";
import BlogList from "../components/blog/BlogList.astro";
import StaticImage from "../components/StaticImage.astro";
import homeImage from "../images/static/naomi-in-stables.jpg";
import { RemoveFinishedWebinars } from "../components/webinar/RemoveFinishedWebinars";
import AutismSummary from "../components/free/AutismSummary.astro";
import DemandAvoidanceSummary from "../components/free/DemandAvoidanceSummary.astro";
import SchoolAndEducationSummary from "../components/free/SchoolAndEducationSummary.astro";
import MentalHealthSummary from "../components/free/MentalHealthSummary.astro";

import Newsletter from "../components/Newsletter.astro";
import NewsletterNew from "../components/NewsletterNew.astro";

import PopUpPanel from "../components/PopUpPanel.astro";

import ResourceCard from "../components/ResourceCard.astro";

const webinars = await getWebinars();

const featuredCourses1 = await getFeaturedCourses(0, 2);
const featuredCourses2 = await getFeaturedCourses(2, 4);

const featuredBooks = await getFeaturedBooks();

const webinarQuotes = (await getEntry("webinar-quotes", "general-webinar-quotes"))!.data;
const coursesQuotes = (await getEntry("course-quotes", "general-course-quotes"))!.data;
const generalQuotes = (await getEntry("static-pages-quotes", "homepage"))!.data;


const metaDescription =
  "Dr Naomi Fisher is a clinical psychologist, author and speaker specialising in parenting, mental health issues in children, autism and trauma. She runs EMDR Basic Training and Refresher Day courses. Dr Abigail Fisher is an education psychologist specialising in Special Educational Needs (SEN), EHCPs, EOTAS. We create courses and webinars for parents and professionals.";
---


<BaseLayout
  active="home"
  pageTitle="Home"
  bodyClassName="home"
  metaDescription={metaDescription}
>
<!-- OLD INTRODUCTION -->
<div class="stacked-page-intro-wrapper" style="display:none">
        <h1 class="">Welcome</h1>

  <div class="page-intro-wrapper">
    <div class="page-intro-image">
      <StaticImage image={homeImage} alt="Naomi by a stable" />
    </div>

    <div class="page-intro-text">

      <!--<h2 class="feature-headline">MENTAL HEALTH COURSE SALE</h2>-->
      <!--<p>Our <a href = "https://courses.naomifisher.co.uk">mental health courses</a> are half price until Sunday. </p>-->


      <p>Dr Naomi Fisher is a clinical psychologist, EMDR-Europe Accredited trainer and author.</p>  <p>Since she was a small child, she
        has asked the world why. Why do things have to be this way – and what would it be like if it were different?</p>

      <p>She applies this to education, parenting and clinical psychology. She asks whether school is always the best
        way for children to learn, and whether the things ‘we all know’ to be true about parenting are in fact the case.

      </p>
      <p>Her work brings
        psychological theory and evidence-based practice together with real life clinical experience and open
        curiosity.</p>

    </div>
  </div>
</div>

<!-- NEW INTRODUCTION -->
<section class="welcome-redesign">
  <div class="welcome-header">
    <h1>WELCOME</h1>
  </div>
  <div class="welcome-content">
    <div class="text-block">
      <p><strong>Dr Naomi Fisher</strong> is a clinical psychologist, EMDR-Europe Accredited trainer and author.</p>
      <p>Since she was a small child, she has asked the world why. Why do things have to be this way - and what would it be like if it were different?</p>
      <p>She applies this to education, parenting and clinical psychology. She asks whether school is always the best way for children to learn, and whether the things 'we all know' to be true about parenting are in fact the case.</p>
      <p>Her work brings psychological theory and evidence-based practice together with real life clinical experience and open curiosity.</p>
    </div>
    <div class="image-placeholder">
    </div>
  </div>
</section>

<!-- WEBINARS ----------------------------------------------  -->
  <a name="webinars" class="anchor">
    <h2 class="section-title">
      <span class="courses-section-title">Live Online Events</span>
      <a href="/webinars" class="section-title-all-link"> See All <span class="desktop-only">Live Online Events</span></a>
    </h2>
  </a>
 <CoursesListV2
    courses={featuredCourses1}
    categoryId="featured"
    categoryName="Featured Courses"
  />

<!-- QUOTE -------------------------------------------------- -->
<GenerateQuote client:load quotes={webinarQuotes} />

<!-- HEADER - free -->
    <a name="webinars" class="anchor">
    <h2 class="section-title">
      <span class="courses-section-title">Free Resources</span>      
      <a href="/resources" class="section-title-all-link"> See All <span class="desktop-only">Free Resources</span></a>
    </h2>
  </a>

<ResourceCard title="New Course: Understanding and Supporting Neurodiverse Children" description="A new course for parents and professionals on understanding and supporting neurodiverse children, including autism, ADHD, dyslexia and more." imageSrc="/images/static/neurodiversity-course.png" imageAlt="Illustration of diverse children" linkUrl="/courses/understanding-and-supporting-neurodiverse-children" linkText="Learn More" />
   

<!-- HEADER on-demand courses -->
<a name="webinars" class="anchor">
    <h2 class="section-title">
      <span class="">On-demand courses</span>
      <a href="/courses" class="section-title-all-link"> See All <span class="desktop-only">Courses</span></a>
    </h2>
  </a>

  <!-- ON_DEMAND COURSES -->
 <CoursesListV2
    courses={featuredCourses1}
    categoryId="featured"
    categoryName="Featured Courses"
  />

  <GenerateQuote client:load quotes={coursesQuotes} />

<!-- BLOG content -->
 <!-- <a name="blog" class="anchor">
    <h2 class="section-title">
      <span class="courses-section-title">Latest Blog Posts</span>
      <a href="/blog" class="section-title-all-link"> See All Blog Posts </a>
    </h2>
  </a>

  <BlogList length="2" /> -->

  <!-- <a href="/blog" class="load-more"> See All Blog Posts </a> -->
<!-- QUOTE -------------------------------------------------- -->
<!-- <GenerateQuote client:load quotes={generalQuotes} /> -->
<!-- HEADER / CONTENT - BOOKS ------ -->
    <!-- <a name="books" class="anchor">
   <h2 class="section-title">
     <span class="">Featured Books</span>
      <a href="/books" class="section-title-all-link"> See All Books </a>
   </h2>
  </a>
  {featuredBooks.map((book) => book && book.data ? <BookSummary book={book.data} /> : null)} -->


<!-- HEADER stay informed -->
<a name="newsletter" class="anchor">
    <h2 class="section-title">
      <span class="courses-section-title">Stay informed</span>
    </h2>
  </a>
  <NewsletterNew formId="6662296"/>




  {
    webinars.length > 0 && (
      <a name="webinars" class="anchor">
        <h2 class="section-title">
          <span class="webinars-section-title">Live Online Events</span>
        </h2>
      </a>

      <div class="page-full-width-text">
        <p>
          Naomi runs live webinars for parents and professionals.
     They are recorded and available to watch for 30 days.</p>

      </div>
    )
  }

  <!-- <Newsletter formId="7379328"/> -->

  <RemoveFinishedWebinars client:load />

  {webinars.map((webinar, index) =>
    <WebinarSummary webinar={webinar} />)}

  <!-- {console.log(webinars.length)}
  {webinars.length % 2 !== 0 && <Newsletter />} -->


 
<GenerateQuote client:load quotes={webinarQuotes} />
  <!-- <div class="page-full-width-text">
    <p>
      Our mini-courses cover topics including <a href="/courses/categories/anxiety">anxiety</a>, <a
      href="/courses/categories/autism">autism</a>, <a href="/courses/categories/demand-avoidance">demand avoidance</a>,
      <a href="/courses/categories/burnout">burnout</a> and <a href="/courses/categories/school">school</a>.</p>
    <p>They are available to watch for 12 months after purchase.</p>
  </div> -->

  <!-- <a href="/courses" class="load-more"> See All Courses </a> -->

  <!-- <a name="free-resources" class="anchor">
    <h2 class="section-title">
      <span class="blog-section-title">Free Resources</span>
    </h2>
  </a> -->

  <!-- <AutismSummary/>
  <DemandAvoidanceSummary/>
  <SchoolAndEducationSummary/>
  <MentalHealthSummary/> -->



  <!--6662296 is the normal newsletter form -->
  <!-- 7379328 is low demand toolkit form -->
