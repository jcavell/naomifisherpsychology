---
import {
  getCoursesWithTagWithoutOtherTags,
  getFeaturedCourses,
  getLatestCourses,
} from "../scripts/courses";
import BaseLayout from "../layouts/BaseLayout.astro";
import CoursesList from "../components/course/CoursesListV2.astro";

import WhitePanel from "../components/WhitePanel.astro";
import { getEntry } from "astro:content";
import StaticImage from "../components/StaticImage.astro";

import homeImage from "../images/static/courses-home.png";
import CourseQuote from "../components/course/CourseQuote.astro";
const featuredCourses1 = await getFeaturedCourses(0, 4);
const featuredCourses2 = await getFeaturedCourses(2, 4);

const metaDescription =
  "Dr Naomi Fisher and Dr Abigail Fisher's courses on helping autistic children with anxiety, screen time, PDA and Demand Avoidance, burnout, What Neurodiversity is, problems at school and EHCP and professional courses on EMDR";
---

<BaseLayout
  active="courses"
  pageTitle="Courses"
  metaDescription={metaDescription}
>
  <a id="courses" class="anchor">
    <h1 class="section-title">
      <span class="courses-section-title">COURSES</span>
    </h1>
  </a>

  <WhitePanel
    title="Our pre-recorded courses provide high quality, affordable information and tips"
    descriptions={[
      " We created our course library when we discovered families were finding it hard to access high quality, affordable psychological information which addressed their children's needs.",
      "They are divided into manageable modules.",
      "You or your child can watch them in your own time for 12 months after purchase.",
      'See our <a href="#faq">Courses FAQ</a> for more information.',
    ]}
    img={homeImage}
    imgAlt="Dr. Naomi Fisher"
  />

  <CourseQuote/>

  <div class="category-badges-wrapper">
    <ul>
      <li><a href="/courses/autism">Autism</a></li>
      <li><a href="/courses/demand-avoidance">Demand Avoidance</a></li>
      <li><a href="/courses/school-and-education">School and Education</a></li>
      <li><a href="/courses/mental-health-and-behaviour">Mental Health and Behaviour</a></li>
    </ul>
  </div>

  <h2 class="section-title">
    <span class="courses-section-title">Featured Courses</span>
  </h2>
  <CoursesList
    courses={featuredCourses1}
    categoryId="featured"
    categoryName="Featured Courses"
  />

  <div class="faq-wrapper">
    <a class="anchor" name="faq">
      <h2 class="section-title">
        <span class="courses-section-title">Courses FAQ</span>
      </h2></a
    >
    <div class="accordion-wrapper">
      <button class="accordion">What is a course?</button>
      <div class="panel">
        <p>
          Our courses are a series of pre-recorded videos that you watch in your
          own time. They are available to watch for 12 months after purchase.
        </p>
      </div>

      <button class="accordion">How do I find a course?</button>
      <div class="panel">
        <p>
          <a href="/courses">Browse our courses</a> to see which ones are of interest.
        </p>
      </div>

      <button class="accordion">How do I watch courses I've purchased?</button>

      <div class="panel">
        <p>
          <a href="https://courses.naomifisher.co.uk/login"
            >Login to our courses website</a
          > to watch your courses.
        </p>
      </div>
      <button class="accordion"
        >How long are courses available to watch for?</button
      >
      <div class="panel">
        <p>They are now available to watch for 12 months after purchase.</p>
      </div>
    </div>
  </div>
</BaseLayout>
