---
import Tags from "../Tags.astro";
import Contributers from "../Contributers.astro";
import Vimeo from "../Vimeo.astro";

import { getWebinarMeta } from "../../scripts/webinarMeta";

import WebinarImage from "./WebinarImage.astro";
import type { Webinar } from "../../types/webinar";

import "../../styles/components/details.scss";
import '../../styles/components/card.scss';

interface Props {
  webinar: Webinar;
}

const { webinar } = Astro.props;

const eventId = webinar.id;
const meta = getWebinarMeta(eventId);

const tickets = webinar.tickets;
const detailsText = webinar.detailsText;
---
<h1 class="section-title">
  <span class="courses-section-title">{webinar.title}</span>
</h1>
<article class="course-card-12 webinars">
  <!-- Header Section -->
  <header class="card-header">
    <div class="top-meta">
       <WebinarImage webinar={webinar} />
      <div class="title-area">
         <p class="subtitle">Live Webinar on Zoom</p>
        <p class="meta">
          Presented by:  <Contributers people={meta?.contributers} /><br
          />
          Date:  {webinar.displayDate.day} {webinar.displayDate.month}, {`${webinar.displayDate.startTime} - ${webinar.displayDate.endTime}`}
        </p>
        <p>
          {webinar.displayDate.day} {webinar.displayDate.month}, {`${webinar.displayDate.startTime} - ${webinar.displayDate.endTime}`}</span>
        <Contributers people={meta?.contributers} /> <br
          />Live Webinar on Zoom<br />         
        </p>
        <div class="action-bar">
           {
          tickets.filter((t) => !t.hidden).map((ticket) => (
            <a href={webinar.url} target="blank">
              <div class="purchase">
                <div class="price">
                  £{((ticket.costValue + ticket.feeValue) / 100).toFixed(2)}
                </div>
                <div class="company eventbrite">{ticket.name}</div>
                <div class="buy-now">
                  <span> Buy Now </span>
                </div>
              </div>
            </a>
          ))
        }
        </div>
      </div>
    </div>

    <!-- <div class="action-bar">
      
      <CourseDetailsAddToBasket
        offerId={course.offerId!}
        priceInPence={priceInPence}
        client:load
      />
    </div> -->
  </header>

  <!-- Main Content Body -->
  <section class="content">
    <div class="description-wrap">
      {webinar.videoData?.embed_url && (
        <figure class="inline-media">
          <Vimeo embedUrl={webinar.videoData.embed_url} />
          <div class="play-overlay">▶</div>
        </figure>
      )}

      <div class="details-body-A" >
      <p set:html={detailsText} />

      {
        webinar.agenda && (
          <h3>Agenda</h3>
          <ul>
            {webinar.agenda.map((a) => (
              <li>{a}</li>
            ))}
          </ul>
        )
      }

      <Vimeo embedUrl={webinar.videoData?.embed_url} />
      </div>
    </div>
  </section>

  <hr class="divider" />

  <div class="footer-cta">
      <Tags tags={meta?.tags} />
    <div class="action-bar">
       {
          tickets.filter((t) => !t.hidden).map((ticket) => (
            <a href={webinar.url} target="blank">
              <div class="purchase">
                <div class="price">
                  £{((ticket.costValue + ticket.feeValue) / 100).toFixed(2)}
                </div>
                <div class="company eventbrite">{ticket.name}</div>
                <div class="buy-now">
                  <span> Buy Now </span>
                </div>
              </div>
            </a>
          ))
        }
    </div>
  </div>
</article>

    <a class="anchor" name="faq">
      <h2 class="section-title">
        <span class="courses-section-title">Webinar FAQs</span>
      </h2></a>
      <div class="accordion-wrapper">
        <button class="accordion">How do I join the live webinar?</button>
        <div class="panel">
          <p>
            This webinar is hosted on Zoom. Please make sure you have Zoom
            installed. We will email you a reminder 2 hours before the event and
            10 minutes before, with the Zoom meeting link
          </p>
        </div>
        <button class="accordion"
        >Can I miss the webinar and watch it later?
        </button
        >
        <div class="panel">
          <p>
            Yes, if you choose the webinar + recording option you can watch it
            in your own time, up to 30 days after the webinar
          </p>
        </div>
        <button class="accordion"
        >When will I be sent a link to the recording?
        </button
        >
        <div class="panel">
          <p>We'll send a link by the morning after the webinar</p>
        </div>
        <button class="accordion"
        >How long can I watch the recording for?
        </button
        >
        <div class="panel">
          <p>You can watch the recording for 30 days after the webinar</p>
        </div>
        <!--<button class="accordion"-->
        <!--&gt;Why is Eventbrite is asking for further information?</button-->
        <!--&gt;-->
        <!--<div class="panel">-->
        <!--  <p>-->
        <!--    You do not need to add any further information to access the webinar-->
        <!--  </p>-->
        <!--</div>-->
        <!--<button class="accordion"-->
        <!--  >Questions about logging in, where are my tickets, refunds, or-->
        <!--  duplicate card charges</button-->
        <!--&gt;-->
        <!--<div class="panel">-->
        <!--  <p>-->
        <!--    Please visit the general Eventbrite FAQ about this: <a-->
        <!--      href="https://www.eventbrite.co.uk/help/en-gb/contact-us/"-->
        <!--      target="_blank">www.eventbrite.co.uk/help/en-gb/contact-us/</a-->
        <!--    >-->
        <!--  </p>-->
        <!--</div>-->
      </div>



<style lang="scss">
  $text-main: #333;
  $accent-green: #d1e5e0;
  $btn-black: #000;
  $border-light: #eee;

  .course-card-12.webinars {
    margin: 0 auto 2rem auto;
    padding: 1rem;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    color: $text-main;

    .live-date {
      top:66px;
    }

    .card-header {
      .top-meta {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
        img,
        picture {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: none;
        }
        .mini-thumb {
          width: 80px;
          height: 80px;
          border-radius: 8px;
          object-fit: cover;
        }

        h1 {
          font-family: "Yanone Kaffeesatz", sans-serif;
          font-optical-sizing: auto;
          font-weight: 400;
          font-style: normal;
          text-transform: uppercase;
          color: #000;
          line-height: 1.1;
          font-size: 40px;
          padding-bottom: 20px;
          padding-top: 20px;
          line-height: 0.9;
        }
        .subtitle {
          display: block;
          text-transform: capitalize;
          font-size: 16px;
          letter-spacing: 0;
          line-height: 1.2;
          margin-bottom: -6px;
          font-weight: 500;
          font-family: Oswald, sans-serif;
          font-optical-sizing: auto;
          font-weight: normal;
          font-style: normal;
          margin-top: 8px;
          line-height: 1.5;
        }
        .title-area p.meta {
          font-size: 14px;
        }

        .contributors {
          background-image: none;
        }

        @media (max-width: 600px) {
          gap: 0;
        }
      }
      @media (max-width: 600px) {
        margin-bottom: 16px;
        gap: 0;
      }
    }

    .divider {
      border: 0;
      border-top: 1px solid $border-light;
      margin: 1.5rem 0;
    }

    .content {
      .description-wrap {
        line-height: 1.6;

        @media (max-width: 600px) {
          display: flex;
          flex-direction: column;
        }

        .inline-media {
          float: right; // Makes text flow around it
          width: 45%; // Smaller size
          margin: 4rem 0 1.5rem 1.5rem;
          position: relative;
          border-radius: 8px;
          overflow: hidden;
          @media (max-width: 600px) {
            margin: 0;
            width: 100%;
          }

          img {
            width: 100%;
            display: block;
          }

          .play-overlay {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.6);
            color: white;
            padding: 10px 15px;
            border-radius: 50%;
          }
        }
      }
    }

    .btn-basket {
      background: $btn-black;
      color: #fff;
      border: none;
      padding: 0.8rem 1.5rem;
      font-weight: bold;
      cursor: pointer;
      border-radius: 4px;
      text-transform: uppercase;
      font-size: 0.8rem;
    }

    .price {
      display: block;
      
     @media(max-width:600px){
            order:3;
          }
    }
    .label {
      font-size: 0.7rem;
      color: #777;
      letter-spacing: 0.5px;
    }

    .agenda-list {
      padding-left: 1.2rem;
      li {
        margin-bottom: 0.5rem;
        color: #444;
      }
    }
    .action-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #f9f9f9;
      padding: 1rem;
      border-left: 2px solid var(--brand-primary);
      margin-top: auto;
      align-items: center;
      flex-direction: column;
      @media (max-width: 600px) {
        margin-top: 1rem;
      }
      > a {
        color:var(--brand-primary);
        text-decoration: none;
        align-self:stretch;
        .purchase {
         
          display:flex;
          justify-content:space-between;
          align-items:center;
          border-bottom:1px solid var(--brand-primary);
          padding:4px 0;
          @media(max-width:600px){
            flex-wrap:wrap;
            gap:12px;
            padding-bottom:12px;
          }

          .buy-now {
    margin-left: auto;
    display: flex;
    align-items: center;
    width:auto;
     @media(max-width:600px){
            order:2;
            margin-left:0;
          }
    span {
      display:inline-block;
    color: #fff;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    cursor: pointer;
    transition: all .3s ease;
    margin: 0;
    outline: none;
    background: var(--success-green);
    justify-self: start;
    width:auto;
    font-size:14px;
    }
          }

        }
         &:last-child .purchase {
            border-bottom-width: 0;
          }
      }

  .buy-now {
    span {
          color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
    margin: 0;
    outline: none;
    background: var(--success-green);
    justify-self: start;
    width: 120px;
    }
    
     @media(max-width:600px){
            order:3;
            margin-left:0;
          }
  }
    }

    span.tags a,
    span.ages a {
      display: inline-block;
      background-color: #d3e4e0;
      padding: 8px;
      border-radius: 8px;
      width: auto;
      font-size: 10px;
      text-decoration: none;
      color: var(--brand-primary);
      margin: 4px 4px 0 0;
    }
  }
  .title-area {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    height: stretch;
    width: stretch;
  }

  // Responsive: Stack image on very small screens
  @media (max-width: 600px) {
    .course-card-12 {
      padding: 0 0 8px 0;
      font-optical-sizing: auto;
      font-weight: normal;
      font-style: normal;
      > *:not(.card-header) {
        padding: 8px;
      }
      .card-header {
        .title-area {
          padding: 0 8px;
        }
        .action-bar {
          margin: 0;
        }
      }
      .top-meta {
        flex-direction: column;
        img {
          max-width: 100%;
          border-radius: 16px 16px 0 0;
        }
      }
      .content {
        .inline-media {
          float: none;
          width: 100%;
          margin: 0 0 1.5rem 0;

          @media (max-width: 600px) {
            margin: 0;
            width: 100%;
          }
        }
      }
    }
  }
</style>
