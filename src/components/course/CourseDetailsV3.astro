---
import Contributers from "../Contributers.astro";
import CourseSummary from "./CourseSummaryV3.astro";
import Tags from "../Tags.astro";
import {
  getCourseFromTitle,
  parseDescriptions,
  getTotalRunningTimeFromDescriptions,
} from "../../scripts/courses";
import CourseImage from "./CourseImage.astro";
import Vimeo from "../Vimeo.astro";
import CourseDetailsAddToBasket from "../basket/CourseDetailsAddToBasket";
import type { CourseCard } from "../../content/config";
import "../../styles/components/details.scss";
import "../../styles/components/card.scss";

interface Props {
  course: CourseCard;
}

const { course } = Astro.props;

const priceInPence = course.priceInPence!;
const checkoutURL = course.checkoutUrl;
const title = course.title;
const descriptions = course.checkout?.descriptions;
const testimonials = course.checkout?.testimonials;

const relatedTitles = course.meta?.relatedTitles || [];

// console.log("COURSE: " + JSON.stringify(course));

// Get related courses
// Filter out possible undefined courses after promises are resolved.
// This happens if the course title in courseMeta is not found in the course cards content
// Cause: the course hasn't been published on Kajabi or hasn't been crawled
const relatedCourses = (
  await Promise.all(relatedTitles.map((title) => getCourseFromTitle(title)))
).filter((c) => c);

// console.log("RELATED COURSES: " + JSON.stringify(relatedCourses));
---

<h1 class="section-title">
  <span class="courses-section-title">{course.title}</span>
</h1>

<article class="course-card-12">
  <!-- Header Section -->
  <header class="card-header">
    <div class="top-meta">
      <CourseImage course={course} />
      <div class="title-area">
        <!-- <h3>
          Presented by: <Contributers people={course.meta?.contributers} />
        </h3> -->
        <p>
          Presented by: <Contributers people={course.meta?.contributers} /><br
          />Recorded course.<br />
          Running time: {course.meta.runningTime}
        </p>
        <!-- <Tags tags={course.meta?.tags} /> -->
        <div class="action-bar">
          <!-- <div class="price-info">
        <span class="price">£40.00</span>
        <span class="label">RECORDED COURSE</span>
      </div> -->
          <CourseDetailsAddToBasket
            offerId={course.offerId!}
            priceInPence={priceInPence}
            client:load
          />
        </div>
      </div>
    </div>

    <!-- <div class="action-bar">
      
      <CourseDetailsAddToBasket
        offerId={course.offerId!}
        priceInPence={priceInPence}
        client:load
      />
    </div> -->
  </header>

  <!-- Main Content Body -->
  <section class="content">
    <div class="description-wrap">
      <!-- The Inline Media: Scaled down and floated -->
      <figure class="inline-media">
        <Vimeo embedUrl={course.meta?.videoUrl} />
        <div class="play-overlay">▶</div>
      </figure>

      <div class="details-body-A" set:html={parseDescriptions(descriptions!)} />
    </div>
  </section>

  <hr class="divider" />

  <div class="footer-cta">
    <Tags tags={course.meta?.tags} />
    <div class="action-bar">
      <!-- <div class="price-info">
        <span class="price">£40.00</span>
        <span class="label">RECORDED COURSE</span>
      </div> -->
      <CourseDetailsAddToBasket
        offerId={course.offerId!}
        priceInPence={priceInPence}
        client:load
      />
    </div>
  </div>
</article>

{
  relatedCourses && (
    <h2 class="section-title">
      <span class="courses-section-title">Related Courses</span>
    </h2>
  )
}
<div class="course-card-grid">
  {
    relatedCourses &&
      relatedCourses.map((related) => <CourseSummary course={related!.data} />)
  }
</div>
<style lang="scss">
  $text-main: #333;
  $accent-green: #d1e5e0;
  $btn-black: #000;
  $border-light: #eee;

  .course-card-12 {
    //max-width: 700px; // Standard reading width
    margin: 0 auto 2rem auto;
    padding: 1rem;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    color: $text-main;

    .card-header {
      .top-meta {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
        img,
        picture {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: none;
        }
        .mini-thumb {
          width: 80px;
          height: 80px;
          border-radius: 8px;
          object-fit: cover;
        }

        h1 {
          font-family: "Yanone Kaffeesatz", sans-serif;
          font-optical-sizing: auto;
          font-weight: 400;
          font-style: normal;
          text-transform: uppercase;
          color: #000;
          line-height: 1.1;
          font-size: 40px;
          padding-bottom: 20px;
          padding-top: 20px;
          line-height: 0.9;
        }
        .subtitle {
          display: block;
          text-transform: capitalize;
          font-size: 16px;
          letter-spacing: 0;
          line-height: 1.2;
          margin-bottom: -6px;
          font-weight: 500;
          font-family: Oswald, sans-serif;
          font-optical-sizing: auto;
          font-weight: normal;
          font-style: normal;
          margin-top: 8px;
          line-height: 1.5;
        }

        .contributors {
          background-image: none;
        }

        @media (max-width: 600px) {
          gap: 0;
        }
      }
      @media (max-width: 600px) {
        margin-bottom: 16px;
        gap: 0;
      }
    }

    .divider {
      border: 0;
      border-top: 1px solid $border-light;
      margin: 1.5rem 0;
    }

    .content {
      .description-wrap {
        line-height: 1.6;

        @media (max-width: 600px) {
          display: flex;
          flex-direction: column;
        }

        .inline-media {
          float: right; // Makes text flow around it
          width: 45%; // Smaller size
          margin: 4rem 0 1.5rem 1.5rem;
          position: relative;
          border-radius: 8px;
          overflow: hidden;
          @media (max-width: 600px) {
            margin: 0;
            width: 100%;
          }

          img {
            width: 100%;
            display: block;
          }

          .play-overlay {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.6);
            color: white;
            padding: 10px 15px;
            border-radius: 50%;
          }
        }
      }
    }

    .btn-basket {
      background: $btn-black;
      color: #fff;
      border: none;
      padding: 0.8rem 1.5rem;
      font-weight: bold;
      cursor: pointer;
      border-radius: 4px;
      text-transform: uppercase;
      font-size: 0.8rem;
    }

    .price {
      font-size: 1.2rem;
      font-weight: 800;
      display: block;
    }
    .label {
      font-size: 0.7rem;
      color: #777;
      letter-spacing: 0.5px;
    }

    .agenda-list {
      padding-left: 1.2rem;
      li {
        margin-bottom: 0.5rem;
        color: #444;
      }
    }
    .action-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #f9f9f9;
      padding: 1rem;
      border-left: 2px solid var(--brand-primary);
      margin-top: auto;
      align-items: center;
      @media (max-width: 600px) {
        margin-top: 1rem;
      }
    }

    span.tags a,
    span.ages a {
      display: inline-block;
      background-color: #d3e4e0;
      padding: 8px;
      border-radius: 8px;
      width: auto;
      font-size: 10px;
      text-decoration: none;
      color: var(--brand-primary);
      margin: 4px 4px 0 0;
    }
  }
  .title-area {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    height: stretch;
    width: stretch;
  }

  // Responsive: Stack image on very small screens
  @media (max-width: 600px) {
    .course-card-12 {
      padding: 0 0 8px 0;
      font-optical-sizing: auto;
      font-weight: normal;
      font-style: normal;
      > *:not(.card-header) {
        padding: 8px;
      }
      .card-header {
        .title-area {
          padding: 0 8px;
        }
        .action-bar {
          margin: 0;
        }
      }
      .top-meta {
        flex-direction: column;
        img {
          max-width: 100%;
          border-radius: 16px 16px 0 0;
        }
      }
      .content {
        .inline-media {
          float: none;
          width: 100%;
          margin: 0 0 1.5rem 0;

          @media (max-width: 600px) {
            margin: 0;
            width: 100%;
          }
        }
      }
    }
  }
</style>
