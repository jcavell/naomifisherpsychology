---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CoursesList from "../../components/course/CoursesListV2.astro";
import type { CourseMeta } from "../../scripts/courseMeta";
import getCourses from "../../scripts/courses";
import StaticImage from "../StaticImage.astro";
import homeImage from "../../images/static/courses-home.png";
import WhitePanel from "../WhitePanel.astro";
import type { ImageMetadata } from "astro";

interface Props {
  courseMeta: CourseMeta[];
  pageTitle: string;
  metaDescription: string;
  whitePanelTitle: string;
  whitePanelDescriptions: string[];
  whitePanelImg: ImageMetadata;
  whitePanelImgAlt: string;
}

const {
  courseMeta,
  pageTitle,
  metaDescription,
  whitePanelTitle,
  whitePanelDescriptions,
  whitePanelImg,
  whitePanelImgAlt,
} = Astro.props;

const courses = await getCourses();
const categoryCourses = courses.filter((course) =>
  courseMeta.includes(course.data.meta!),
);

const allDescriptions = whitePanelDescriptions.concat("All courses are available to watch for 12 months");
---

<BaseLayout
  active="courses"
  pageTitle={pageTitle}
  metaDescription={metaDescription}
>
  <a name="welcome" class="anchor">
    <h1 class="section-title">
      <span class="courses-section-title">{pageTitle}</span>
    </h1>
  </a>

  <WhitePanel
    title={whitePanelTitle}
    descriptions={allDescriptions}
    img={whitePanelImg}
    imgAlt={whitePanelImgAlt}
  />

  <div class="category-badges-wrapper">
    <ul>
      <li><a href="/courses-sub-list">Essentials</a></li>
      <li><a href="/courses-sub-list">Anxiety</a></li>
      <li><a href="/courses-sub-list">Trauma</a></li>
      <li><a href="/courses-sub-list">OCD</a></li>
    </ul>
  </div>

  <CoursesList courses={categoryCourses} categoryId="" categoryName="" />

</BaseLayout>
