---
import Tags from "../Tags.astro";
import BlogImage from "./BlogImage.astro";
import { getTaggedCourses } from "../../scripts/getTaggedResources";
import getCourses from "../../scripts/courses";
import { makeUrl } from "../../scripts/url";
import { getTags } from "../../scripts/tags";
import "../../styles/components/details.scss";
import "../../styles/components/card.scss";

const { post } = Astro.props;

const title = post.title;
const subtitle = post.subtitle;
const pubDate = post.pubDate;
const paragraphs = post.paragraphs;

const tags = getTags(title, subtitle, paragraphs.join(" "));

const courses = await getCourses();

// Filter out nulls or elements with no data or title
// This can happen if there is an entry in courseMeta but not from Kajabi
const relatedCourses = getTaggedCourses(courses, [tags[0]]).filter(
  (c) => c?.data?.title,
);

// console.log("RELATED: " + JSON.stringify(relatedCourses));
---

<!-- <style is:global>
  /* Target the specific accordion in the related courses section */
  .details-body-B .accordion-wrapper .accordion.no-title-accordion {
    border-top: none !important;
  }
</style> -->
<a name="blogs" class="anchor">
  <h1 class="section-title">
    <span class=""> {title}</span>
  </h1>
</a>
<article class="course-card-12">
  <!-- Header Section -->

  <!-- Main Content Body -->
  <section class="content">
    <div class="description-wrap">
      <!-- The Inline Media: Scaled down and floated -->
      <!-- <figure class="inline-media">
        <Vimeo embedUrl={course.meta?.videoUrl} />
        <div class="play-overlay">▶</div>
      </figure> -->

      <div class="details-body-A">
        {
          post.imagePrefix && (
            <BlogImage post={post} alt={`Image for ${title}`} />
          )
        }
        <h2>{subtitle}</h2>
        {paragraphs.map((p, i) => <p>{paragraphs[i]}</p>)}
      </div>
    </div>

    <hr class="divider" />
    <div class="card-meta">
      <!--<Tags tags={tags} />-->
    </div>

    <hr class="divider" />
    <div class="footer-cta">
      <!-- <Tags tags={course.meta?.tags} /> -->
      <div class="action-bar">
        <h3>Related Courses</h3>
        {
          relatedCourses.slice(0, 1).map((course) => (
            <a href={`/courses/${makeUrl(course.data.title)}`}>
              <div class="purchase">
                <div class="company">{course.data.title}</div>
                <div class="buy-now">
                  <span> View </span>
                </div>
              </div>
            </a>
          ))
        }

        <div class="accordion-wrapper">
          <button class="accordion no-title-accordion">See More</button>
          <div class="panel">
            {
              relatedCourses.slice(1, 6).map((course) => (
                <a href={`/courses/${makeUrl(course.data.title)}`}>
                  <div class="purchase">
                    <div class="company">{course.data.title}</div>
                    <div class="buy-now">
                      <span> View </span>
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <style lang="scss">
    $text-main: #333;
    $accent-green: #d1e5e0;
    $btn-black: #000;
    $border-light: #eee;
    h1.section-title,
    h2 {
      text-transform: none;
    }
    .course-card-12 {
      //max-width: 700px; // Standard reading width
      margin: 0 auto 2rem auto;
      padding: 1rem;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      color: $text-main;

      .footer-cta {
        margin-bottom: 0.5rem;
      }

      .card-header {
        .top-meta {
          display: flex;
          align-items: center;
          gap: 1.5rem;
          margin-bottom: 1.5rem;
          img,
          picture {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
          }
          .mini-thumb {
            width: 80px;
            height: 80px;
            border-radius: 8px;
            object-fit: cover;
          }

          h1 {
            font-family: "Yanone Kaffeesatz", sans-serif;
            font-optical-sizing: auto;
            font-weight: 400;
            font-style: normal;
            text-transform: uppercase;
            color: #000;
            line-height: 1.1;
            font-size: 40px;
            padding-bottom: 20px;
            padding-top: 20px;
            line-height: 0.9;
          }
          .subtitle {
            display: block;
            text-transform: capitalize;
            font-size: 16px;
            letter-spacing: 0;
            line-height: 1.2;
            margin-bottom: -6px;
            font-weight: 500;
            font-family: Oswald, sans-serif;
            font-optical-sizing: auto;
            font-weight: normal;
            font-style: normal;
            margin-top: 8px;
            line-height: 1.5;
            @media (min-width: 600px) {
              margin-top: 0;
            }
          }

          .contributors {
            background-image: none;
          }

          @media (max-width: 600px) {
            gap: 0;
          }
        }
        @media (max-width: 600px) {
          margin-bottom: 16px;
          gap: 0;
        }
      }

      .divider {
        border: 0;
        border-top: 1px solid $border-light;
        margin: 1.5rem 0;
      }

      .content {
        .description-wrap {
          line-height: 1.6;

          @media (max-width: 600px) {
            display: flex;
            flex-direction: column;
          }

          img {
            max-width: 250px;
            float: left;
            margin: 0 16px 16px 0;
          }

          .inline-media {
            float: right; // Makes text flow around it
            width: 45%; // Smaller size
            margin: 4rem 0 1.5rem 1.5rem;
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            @media (max-width: 768px) {
              width: 100%;
            }

            img {
              width: 100%;
              display: block;
            }

            .play-overlay {
              position: absolute;
              top: 50%;
              left: 50%;
              transform: translate(-50%, -50%);
              background: rgba(0, 0, 0, 0.6);
              color: white;
              padding: 10px 15px;
              border-radius: 50%;
            }
          }
        }
        .card-meta {
          border-top-width: 0;
          span.tags {
            margin: 0;
          }
        }
      }

      .btn-basket {
        background: $btn-black;
        color: #fff;
        border: none;
        padding: 0.8rem 1.5rem;
        font-weight: bold;
        cursor: pointer;
        border-radius: 4px;
        text-transform: uppercase;
        font-size: 0.8rem;
      }

      .price {
        font-size: 1.2rem;
        font-weight: 800;
        display: block;
      }
      .label {
        font-size: 0.7rem;
        color: #777;
        letter-spacing: 0.5px;
      }

      .agenda-list {
        padding-left: 1.2rem;
        li {
          margin-bottom: 0.5rem;
          color: #444;
        }
      }
      .action-bar {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        background: #f9f9f9;
        padding: 1rem;
        border-left: 2px solid var(--brand-primary);
        margin-top: auto;
        @media (max-width: 600px) {
          margin-top: 1rem;
        }
        h3 {
          margin-bottom: 0;
          color: var(--brand-primary);
          text-transform: uppercase;
        }
        a {
          text-decoration: none !important;
          font-family: "Oswald", sans-serif;
          font-optical-sizing: auto;
          font-weight: 500;
          font-style: normal;
          .purchase {
            color: #000;
            position: relative;
            display: flex;

            height: 56px;
            align-items: center;
            .buy-now {
              span {
                display: block;
                text-decoration: none;
                text-transform: uppercase;
                color: #fff;
                background: #387668;
                text-decoration: none;
                padding-left: 16px;
                padding-right: 16px;
                padding-top: 6px;
                padding-bottom: 6px;
                border-radius: 10px;
              }
            }
          }
          &:hover {
            .purchase {
              // background-color: #ffffff;
              .buy-now {
                span {
                  background-color: var(--brand-light-bg);
                  color: var(--brand-primary);
                }
              }
            }
          }
        }
        .accordion-wrapper {
          margin-top: 0;
          .accordion.no-title-accordion:first-child {
            margin-top: 0;
          }
        }
        .company {
          background-repeat: no-repeat;
          background-position: left center;
          background-size: auto 100%;
          flex: 1;
          position: relative;
          min-height: 24px;
        }
      }

      span.tags a,
      span.ages a {
        display: inline-block;
        background-color: #d3e4e0;
        padding: 8px;
        border-radius: 8px;
        width: auto;
        font-size: 10px;
        text-decoration: none;
        color: var(--brand-primary);
        margin: 4px 4px 0 0;
      }
    }
    .title-area {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      height: stretch;
      align-self: stretch;
    }

    // Responsive: Stack image on very small screens
    @media (max-width: 600px) {
      .course-card-12 {
        padding: 0 0 8px 0;
        font-optical-sizing: auto;
        font-weight: normal;
        font-style: normal;
        > *:not(.card-header) {
          padding: 12px;
        }
        .card-header {
          .title-area {
            padding: 0;
          }
          .action-bar {
            margin: 0;
          }
        }
        .top-meta {
          flex-direction: column;
          img {
            max-width: 100%;
            border-radius: 16px 16px 0 0;
          }
        }
        .content {
          .inline-media {
            float: none;
            width: 100%;
            margin: 0 0 1.5rem 0;

            @media (max-width: 600px) {
              margin: 0;
              width: 100%;
            }
          }
        }
      }
    }
  </style>
</article>
