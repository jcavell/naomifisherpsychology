            <div class="purchase-title">
              <div class="purchase-title-primary purchase-title-audiobook">
                AUDIOBOOK
              </div>
              <div class="purchase-title-secondary">
                Running Time: {book.audiobookLength}
              </div>
            </div>

            {book.audibleUrl && (
              <a href={book.audibleUrl} target="blank">
