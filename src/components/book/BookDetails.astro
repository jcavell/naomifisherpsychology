        <!--      <div class="purchase">-->
        <!--        <div class="price">{book.waterstonesPrice}</div>-->
        <!--        <div class="company waterstones" />{" "}-->
        <!--      </div>-->
        <!--    </a>-->
        <!--  )-->
        <!--}-->
      </div>

      {
        (book.kindleUrl) && (
          <>
            <div class="purchase-wrapper">
              <div class="purchase-title">
                <div class="purchase-title-primary purchase-title-eBook">
