---

<script src="../scripts/carousel.ts"></script>
<div class="carousel-container">
  <button class="carousel-btn prev" data-carousel-btn="prev">&#10094;</button>
  <div class="carousel-track-container">
    <div class="carousel-track">
      <!-- Slide 1: Sale Promotion -->
      <div class="carousel-slide slide-sale">
        <div class="slide-content">
          <h1>New Course Launched</h1>
          <p class="desktop-item">
            Helping and Understanding Your Demand Avoidant adolescent
          </p>
          <a href="#" class="btn">View Course</a>
        </div>
      </div>

      <!-- Slide 2: New Courses -->
      <div class="carousel-slide slide-new-courses">
        <div class="slide-content">
          <h1>Book Sale Now On</h1>
          <p class="desktop-item">
            Explore Dr Naomi Fisher's range of books...
          </p>
          <a href="#" class="btn">View Books</a>
        </div>
      </div>

      <!-- Slide 3: Live Seminars -->
      <div class="carousel-slide slide-seminars">
        <div class="slide-content">
          <h1>Upcoming Live Webinars</h1>
          <p class="desktop-item">Join live events with Dr. Naomi Fisher</p>
          <a href="#" class="btn">See All Events</a>
        </div>
      </div>
    </div>
  </div>
  <button class="carousel-btn next" data-carousel-btn="next">&#10095;</button>

  <div class="carousel-nav-dots">
    <button class="nav-dot active" data-slide-index="0"></button>
    <button class="nav-dot" data-slide-index="1"></button>
    <button class="nav-dot" data-slide-index="2"></button>
  </div>
</div>
